{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      // 디버거 종류 (node: Node.js 디버거 사용)
      "type": "node",
      // 디버그 방식 (launch: VSCode가 직접 프로세스를 실행)
      "request": "launch",
      // VSCode 디버그 패널에 표시될 이름
      "name": "Debug NestJS",
      // 실행할 런타임 (npm 명령어를 사용)
      "runtimeExecutable": "npm",
      // npm에 전달할 인자 (npm run start:debug 실행)
      "runtimeArgs": ["run", "start:debug"],
      // 터미널 출력 위치 (integratedTerminal: VSCode 내장 터미널 사용)
      "console": "integratedTerminal",
      // 프로세스 종료 시 자동으로 재시작 여부
      "restart": true,
      "port": 9229,
      // 자식 프로세스(워커 등)에도 자동으로 디버거 연결 여부
      "autoAttachChildProcesses": true
    }
  ]
}
